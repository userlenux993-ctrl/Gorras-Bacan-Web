{
  "buildCommand": "pnpm --filter @workspace/gorritas-el-bacan run build",
  "outputDirectory": "artifacts/gorritas-el-bacan/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/api(/.*)?$", "status": 404 },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
